# =============================================================================
# Klinika CRM frontend (Next.js) — Phase 8A
# =============================================================================
# Bu fayl FAQAT namuna. Haqiqiy qiymatlarni `.env.local` ga yozing (gitignore).

# Backend (NestJS) ning ICHKI (server-to-server) manzili. Brauzer bu URL'ni
# ko'rmaydi — Next.js BFF (route handlers) shu orqali murojaat qiladi.
BACKEND_INTERNAL_URL=http://127.0.0.1:3000

# Cookie'lar `Secure` bo'lishi kerakmi (HTTPS prod uchun true). Dev'da false.
COOKIE_SECURE=false
