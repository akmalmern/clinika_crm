# =============================================================================
# Klinika CRM — Backend muhit o'zgaruvchilari (NAMUNA)
# Bu faylni `.env` ga nusxalang:  cp .env.example .env
# DIQQAT: haqiqiy `.env` HECH QACHON commit qilinmaydi (.gitignore'da).
# =============================================================================

# --- Ilova ---
NODE_ENV=development
PORT=3000
# Vergul bilan ajratilgan ruxsat etilgan originlar (frontend) yoki * (faqat dev)
CORS_ORIGINS=http://localhost:3001
# Standart til: uz | ru | en
DEFAULT_LOCALE=uz

# --- Ma'lumotlar bazasi (PostgreSQL) ---
# Lokal (docker tashqarisida) ishlatish uchun host=localhost.
# docker-compose backend'i bu qiymatni servis nomiga (postgres) o'zgartiradi.
DATABASE_URL=postgresql://clinic:clinic_pass@localhost:5432/clinic_crm?schema=public

# docker-compose tomonidan o'qiladigan postgres sozlamalari
POSTGRES_USER=clinic
POSTGRES_PASSWORD=clinic_pass
POSTGRES_DB=clinic_crm
POSTGRES_PORT=5432

# --- Redis (refresh token, blacklist, kelajakda cache/sessiya) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_pass

# --- JWT ---
# Production'da kuchli, tasodifiy maxfiy kalitlar ishlating (masalan: openssl rand -base64 48)
JWT_ACCESS_SECRET=change_me_access_secret_dev_only
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=change_me_refresh_secret_dev_only
JWT_REFRESH_EXPIRES=7d

# --- Rate limiting (global throttler) ---
THROTTLE_TTL=60000
THROTTLE_LIMIT=120

# --- MinIO / S3 (fayl moduli, Phase 4) ---
# Lokal (Docker tashqarisida) MINIO_ENDPOINT=127.0.0.1; docker-compose -> 'minio'
MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=clinic-files
MINIO_CONSOLE_PORT=9001
# Signed (vaqtinchalik) URL muddati (sekund) va bitta fayl maks hajmi (MB)
STORAGE_SIGNED_URL_TTL=300
STORAGE_MAX_FILE_MB=15

# --- Scheduling / Qabul (Phase 5B) ---
# Klinika mahalliy vaqt offseti (daqiqa). Asia/Tashkent = UTC+5 = 300.
CLINIC_TZ_OFFSET_MINUTES=300

# --- Reports / Hisobot (Phase 7B) ---
# Og'ir agregat hisobot natijasini Redis'da keshlash muddati (sekund). 0 -> o'chiq.
REPORTS_CACHE_TTL_SEC=60

# --- Notification / SMS (Phase 7A) ---
# SMS provayderi: log (dev — faqat loglaydi) | eskiz
SMS_PROVIDER=log
# Qabuldan necha daqiqa oldin eslatma yuborilsin
NOTIFY_REMINDER_LEAD_MIN=60
# Eskiz.uz (DIQQAT: sirlar faqat shu yerda)
ESKIZ_BASE_URL=https://notify.eskiz.uz/api
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_FROM=4546

# --- Telegram bot (Phase 7A). Bo'sh bo'lsa bot ishga tushmaydi (dev). ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
# Webhook secret (production). Domen berilsa webhook, bo'lmasa polling (dev).
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_DOMAIN=
# "Ilovaga kiring" havolalari uchun ilovaning ommaviy URL'i
APP_PUBLIC_URL=http://localhost:3001

# --- Billing / Obuna (Phase 2-3) ---
# Yangi klinika TRIAL bilan boshlanganda necha kun sinov muddati
TRIAL_DAYS=14
# Standart valyuta (tariflar uchun)
DEFAULT_CURRENCY=UZS
# To'lov muddati o'tgach beriladigan qo'shimcha muhlat (kun). O'tsa -> SUSPENDED.
GRACE_DAYS=3
# Kunlik billing cron (UTC). Standart: har kuni 02:00.
BILLING_CRON=0 2 * * *

# --- Payme (Merchant API). DIQQAT: sirlar faqat shu yerda, kodda EMAS. ---
# Payme kabinetidan olinadi. Webhook himoyasi shu MERCHANT_KEY (Basic auth) bilan.
PAYME_MERCHANT_ID=
PAYME_MERCHANT_KEY=
# Test (sandbox) kaliti — ixtiyoriy.
PAYME_TEST_KEY=
# `account` ob'ektida invoice'ni aniqlovchi maydon (Payme kabinetida sozlanadi).
PAYME_ACCOUNT_FIELD=invoice_id

# --- Click (Merchant API) ---
CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=
# sign_string (MD5) tekshiruvi uchun maxfiy kalit.
CLICK_SECRET_KEY=
CLICK_MERCHANT_USER_ID=

# --- Boshlang'ich Super Admin (seed script ishlatadi) ---
SUPER_ADMIN_NAME=Platform Owner
SUPER_ADMIN_EMAIL=admin@clinic-crm.uz
SUPER_ADMIN_PASSWORD=Admin12345!
