// =============================================================================
// Klinika CRM — Prisma schema (Phase 1)
// =============================================================================
// QOIDALAR (spec 1.5 / 1.6):
//  - Barcha PK -> UUID v7 (app-layer'da `uuidv7()` orqali inject qilinadi —
//    qarang: core/prisma/prisma-extensions.ts). Schema'dagi @default(uuid())
//    faqat (a) Prisma create-input'da `id`ni ixtiyoriy qiladi (TS uchun) va
//    (b) extension biror sababga ko'ra ishlamasa, fallback bo'ladi. Haqiqiy
//    qiymat har doim UUID v7 (extension), bu DB-level default EMAS (app-level).
//  - Vaqt -> har doim @db.Timestamptz(6) (UTC).
//  - status/role/category kabi maydonlar PostgreSQL enum EMAS -> String
//    + ilova darajasida validatsiya (additive o'zgarishlar uchun).
//  - Soft-delete -> deleted_at. Unique cheklovlar PARTIAL unique index sifatida
//    (WHERE deleted_at IS NULL) hand-authored migration SQL'da yaratiladi,
//    chunki Prisma schema partial unique'ni ifodalay olmaydi. Shu sababli bu
//    yerda @unique YO'Q — kodda findUnique emas, findFirst ishlatiladi.
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---- PLATFORMA (SaaS) — bu jadvallarda clinic_id BO'LMAYDI ----

/// Platforma egasi(lari). Tenant'ga tegishli emas.
model SuperAdmin {
  id           String    @id @default(uuid()) @db.Uuid
  fullName     String    @map("full_name")
  email        String
  passwordHash String    @map("password_hash")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)

  // Partial unique (email) WHERE deleted_at IS NULL -> migration SQL'da
  @@map("super_admins")
}

/// Klinika = tenant. Uning `id` boshqa jadvallarda `clinic_id` bo'ladi.
model Clinic {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  slug      String
  status    String    @default("ACTIVE") // ACTIVE | TRIAL | SUSPENDED | ... (app-validated)
  logoUrl   String?   @map("logo_url")
  address   String?
  phone     String?
  email     String?
  settings  Json      @default("{}")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  members           ClinicMember[]
  subscriptions     Subscription[]
  invoices          Invoice[]
  files             File[]
  patients          Patient[]
  serviceCategories ServiceCategory[]
  services          Service[]
  // Eslatma: Transaction.clinicId — denormalizatsiya (tenant filtri/hisobot uchun),
  // clinics'ga FK YO'Q (faqat invoices'ga FK). Shu sababli bu yerda relation yo'q.

  // Partial unique (slug) WHERE deleted_at IS NULL -> migration SQL'da
  @@index([status])
  @@map("clinics")
}

// ---- KLINIKA ICHIDAGI FOYDALANUVCHILAR ----

/// Foydalanuvchi = global identifikator (insondan biri). Klinikadagi a'zoligi
/// `clinic_members` orqali. Bir foydalanuvchi bir nechta klinikada bo'lishi mumkin.
model User {
  id           String    @id @default(uuid()) @db.Uuid
  fullName     String    @map("full_name")
  phone        String?
  email        String?
  passwordHash String    @map("password_hash")
  isActive     Boolean   @default(true) @map("is_active")
  avatarUrl    String?   @map("avatar_url")
  birthDate    DateTime? @map("birth_date") @db.Date
  gender       String?
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)

  memberships ClinicMember[]

  @@index([email])
  @@index([phone])
  @@map("users")
}

/// Klinikadagi a'zolik + rol. Tenant'ga tegishli (clinic_id bor).
model ClinicMember {
  id             String    @id @default(uuid()) @db.Uuid
  clinicId       String    @map("clinic_id") @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  role           String // CLINIC_ADMIN | DOCTOR | RECEPTIONIST | NURSE | CASHIER (app-validated)
  position       String?
  specialization String?
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  // Partial unique (user_id, clinic_id) WHERE deleted_at IS NULL -> migration SQL'da
  @@index([clinicId])
  @@index([userId])
  @@map("clinic_members")
}

// ---- AUDIT (append-only / immutable) ----

/// Audit log. updated_at/deleted_at YO'Q — faqat qo'shiladi, o'zgartirilmaydi.
/// clinic_id null bo'lishi mumkin (super admin harakatlari uchun).
/// Tashqi FK qo'yilmaydi — log egasi o'chsa ham saqlanib qolsin (immutability).
/// Phase 9B: VAQT bo'yicha oylik PARTITION — PK partition kalitini (created_at)
/// o'z ichiga oladi (@@id([id, createdAt])). Partition CHILD jadvallari ops/db
/// skriptlari bilan boshqariladi (prod: `migrate deploy`).
model AuditLog {
  id        String   @default(uuid()) @db.Uuid
  clinicId  String?  @map("clinic_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  actorType String   @map("actor_type") // SUPER_ADMIN | USER | SYSTEM
  action    String // AUTH_LOGIN | AUTH_LOGOUT | FILE_DOWNLOAD | ...
  entity    String?
  entityId  String?  @map("entity_id")
  metadata  Json     @default("{}")
  ip        String?
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@id([id, createdAt])
  @@index([clinicId, createdAt])
  @@index([userId])
  @@index([entity, entityId])
  @@map("audit_logs")
}

// ---- OBUNA / TARIFLAR (Platforma <-> Klinika) ----

/// Tarif (BASIC/STANDARD/PREMIUM). Platforma darajasida — clinic_id BO'LMAYDI.
/// Pul Decimal sifatida (Float EMAS, spec 1.5). limits/features — JSON.
model SubscriptionPlan {
  id           String    @id @default(uuid()) @db.Uuid
  name         String
  price        Decimal   @db.Decimal(14, 2)
  currency     String    @default("UZS")
  billingCycle String    @map("billing_cycle") // MONTHLY | YEARLY (app-validated)
  limits       Json      @default("{}") // { maxStaff, maxPatients, storageGb, smsCount }
  features     Json      @default("{}") // { pharmacy, telegram, ... }
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)

  subscriptions Subscription[]

  // Partial unique (name) WHERE deleted_at IS NULL -> migration SQL'da
  @@index([isActive])
  @@map("subscription_plans")
}

/// Klinika obunasi. Tenant'ga tegishli (clinic_id bor).
/// status: ACTIVE | TRIAL | PAST_DUE | SUSPENDED | CANCELLED (DB enum EMAS).
model Subscription {
  id              String    @id @default(uuid()) @db.Uuid
  clinicId        String    @map("clinic_id") @db.Uuid
  planId          String    @map("plan_id") @db.Uuid
  status          String    @default("TRIAL")
  startDate       DateTime  @map("start_date") @db.Timestamptz(6)
  endDate         DateTime? @map("end_date") @db.Timestamptz(6)
  nextBillingDate DateTime? @map("next_billing_date") @db.Timestamptz(6)
  graceUntil      DateTime? @map("grace_until") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz(6)

  clinic   Clinic           @relation(fields: [clinicId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  plan     SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  invoices Invoice[]

  @@index([clinicId])
  @@index([status, nextBillingDate])
  @@map("subscriptions")
}

// ---- HISOB-FAKTURALAR (Platforma -> Klinika, abonent to'lovi) ----
// Obuna sikli kelganda cron avtomatik invoice yaratadi. Pul Decimal (Float EMAS).
// debt_amount = total_amount - paid_amount (denormalized — tez so'rov uchun).
// status: UNPAID | PARTIAL | PAID | OVERDUE | CANCELLED (DB enum EMAS — string).
model Invoice {
  id             String    @id @default(uuid()) @db.Uuid
  clinicId       String    @map("clinic_id") @db.Uuid
  subscriptionId String?   @map("subscription_id") @db.Uuid
  invoiceNumber  String    @map("invoice_number")
  totalAmount    Decimal   @map("total_amount") @db.Decimal(14, 2)
  paidAmount     Decimal   @default(0) @map("paid_amount") @db.Decimal(14, 2)
  debtAmount     Decimal   @map("debt_amount") @db.Decimal(14, 2)
  currency       String    @default("UZS")
  status         String    @default("UNPAID")
  // Obuna davri (qaysi sikl uchun): idempotentlik kaliti (subscription_id, period_start).
  periodStart    DateTime? @map("period_start") @db.Timestamptz(6)
  periodEnd      DateTime? @map("period_end") @db.Timestamptz(6)
  dueDate        DateTime  @map("due_date") @db.Timestamptz(6)
  paidAt         DateTime? @map("paid_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)

  clinic       Clinic        @relation(fields: [clinicId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  transactions Transaction[]

  // Partial unique: invoice_number; (subscription_id, period_start) -> migration SQL'da
  @@index([clinicId, status])
  @@index([clinicId, createdAt])
  @@index([status, dueDate])
  @@map("invoices")
}

// ---- TRANZAKSIYALAR (to'lov yozuvlari — moliyaviy ledger, soft-delete YO'Q) ----
// provider: PAYME | CLICK | MANUAL. Idempotency: (provider, provider_tx_id) unique.
// state — provayderga xos raqamli holat (Payme: 1,2,-1,-2). raw — to'liq payload.
model Transaction {
  id           String    @id @default(uuid()) @db.Uuid
  clinicId     String    @map("clinic_id") @db.Uuid
  invoiceId    String    @map("invoice_id") @db.Uuid
  provider     String
  method       String? // CASH | BANK_TRANSFER | CARD | ONLINE
  providerTxId String?   @map("provider_tx_id")
  reference    String?
  amount       Decimal   @db.Decimal(14, 2)
  status       String    @default("PENDING") // PENDING | PAID | CANCELLED | FAILED
  state        Int?
  cancelReason Int?      @map("cancel_reason")
  performedAt  DateTime? @map("performed_at") @db.Timestamptz(6)
  cancelledAt  DateTime? @map("cancelled_at") @db.Timestamptz(6)
  confirmedBy  String?   @map("confirmed_by") @db.Uuid
  raw          Json      @default("{}")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  // Partial unique (provider, provider_tx_id) WHERE provider_tx_id IS NOT NULL -> migration SQL'da
  @@index([clinicId, createdAt])
  @@index([invoiceId])
  @@index([provider, status])
  // Hisobot (Phase 7B): platforma daromadi PAID tranzaksiyalar performed_at bo'yicha.
  @@index([status, performedAt])
  @@map("transactions")
}

// ---- UNIVERSAL FAYL/HUJJAT JADVALI (Phase 4, spec 6) ----
// Polimorfik: bitta jadval istalgan obyektga (xodim/bemor/klinika/tibbiy yozuv)
// bog'lanadi -> har hujjat turi uchun alohida ustun YO'Q. Fayllarning O'ZI
// MinIO/S3'da; bazada faqat metadata (storage_key, ...). DB-level polimorfik FK
// yo'q (owner_type/owner_id) -> egasi o'chsa cleanup job tozalaydi (spec 8).
model File {
  id           String    @id @default(uuid()) @db.Uuid
  clinicId     String    @map("clinic_id") @db.Uuid
  ownerType    String    @map("owner_type") // USER | PATIENT | CLINIC | MEDICAL_RECORD (app-validated)
  ownerId      String    @map("owner_id") @db.Uuid
  category     String // PROFILE_PHOTO | PASSPORT | DIPLOMA | ... (app-validated)
  storageKey   String    @map("storage_key") // MinIO/S3 dagi yo'l (object key)
  originalName String    @map("original_name")
  mimeType     String    @map("mime_type")
  size         BigInt // bayt (BigInt — klinika umumiy hajmini xavfsiz yig'ish uchun)
  uploadedBy   String?   @map("uploaded_by") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  // Fayllarni tez topish uchun composite index (spec 8 MUHIM QOIDA)
  @@index([clinicId, ownerType, ownerId])
  @@index([clinicId, createdAt])
  @@index([ownerType, ownerId])
  @@map("files")
}

// ---- BEMORLAR (Phase 5A, spec 7.4) ----
// Tenant-scoped (clinic_id). Rasm/hujjatlar files moduli orqali (owner_type=PATIENT).
// avatar_url -> profil rasm fayl id (files.id), signed URL bilan ko'rsatiladi.
model Patient {
  id        String    @id @default(uuid()) @db.Uuid
  clinicId  String    @map("clinic_id") @db.Uuid
  fullName  String    @map("full_name")
  birthDate DateTime? @map("birth_date") @db.Date
  gender    String? // MALE | FEMALE | OTHER (app-validated)
  phone     String?
  address   String?
  bloodType String?   @map("blood_type") // A+, O-, ... (app-validated)
  allergies String?
  avatarUrl String?   @map("avatar_url") // PROFILE rasm fayl id (files.id)
  notes     String?
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  clinic          Clinic           @relation(fields: [clinicId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  appointments    Appointment[]
  patientInvoices PatientInvoice[]
  medicalRecords  MedicalRecord[]

  @@index([clinicId, createdAt])
  @@index([clinicId, fullName])
  @@index([clinicId, phone])
  @@map("patients")
}

// ---- XIZMAT KATEGORIYALARI (Phase 5A, spec 7.8) ----
model ServiceCategory {
  id          String    @id @default(uuid()) @db.Uuid
  clinicId    String    @map("clinic_id") @db.Uuid
  name        String
  description String?
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  clinic   Clinic    @relation(fields: [clinicId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  services Service[]

  // Partial unique (clinic_id, name) WHERE deleted_at IS NULL -> migration SQL'da
  @@index([clinicId])
  @@map("service_categories")
}

// ---- XIZMATLAR (Phase 5A, spec 7.8) ----
// Pul Decimal (Float EMAS). Narx o'zgarsa service_price_history'ga yoziladi.
// Soft-delete -> eski qabullardagi narx tarixiga ta'sir qilmaydi (spec 7.8).
model Service {
  id         String    @id @default(uuid()) @db.Uuid
  clinicId   String    @map("clinic_id") @db.Uuid
  categoryId String?   @map("category_id") @db.Uuid
  name       String
  price      Decimal   @db.Decimal(14, 2)
  currency   String    @default("UZS")
  duration   Int? // daqiqa (qabul davomiyligi)
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz(6)

  clinic       Clinic                @relation(fields: [clinicId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  category     ServiceCategory?      @relation(fields: [categoryId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  priceHistory ServicePriceHistory[]
  appointments Appointment[]

  @@index([clinicId, isActive])
  @@index([clinicId, categoryId])
  @@map("services")
}

// ---- NARX TARIXI (Phase 5A, spec 7.8 — append-only) ----
// Har narx o'zgarishida bitta yozuv: kim (changed_by), qachon, eski -> yangi.
// Soft-delete YO'Q (tarix o'chirilmaydi).
model ServicePriceHistory {
  id        String   @id @default(uuid()) @db.Uuid
  clinicId  String   @map("clinic_id") @db.Uuid
  serviceId String   @map("service_id") @db.Uuid
  oldPrice  Decimal  @map("old_price") @db.Decimal(14, 2)
  newPrice  Decimal  @map("new_price") @db.Decimal(14, 2)
  changedBy String?  @map("changed_by") @db.Uuid
  changedAt DateTime @default(now()) @map("changed_at") @db.Timestamptz(6)

  service Service @relation(fields: [serviceId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([clinicId, serviceId])
  @@index([serviceId, changedAt])
  @@map("service_price_history")
}

// =============================================================================
// Phase 5B — Qabul (Appointment) va Kassa (bemor to'lovlari)
// =============================================================================
// Eslatma: doctor_id va clinic_id — UUID ustunlar (FK migration SQL'da: doctor_id ->
// users, clinic_id -> clinics). Prisma relation faqat Phase 5B grafida (Patient/
// Service/Appointment/PatientInvoice/PatientPayment) — Clinic/User modellari
// shishirilmasin (Transaction'dagi kabi yondashuv).

// ---- SHIFOKOR ISH JADVALI (spec 7.6 / 8) ----
// weekday: 0=Yakshanba .. 6=Shanba (Asia/Tashkent, UTC+5). start_time/end_time —
// "HH:MM" (mahalliy vaqt). Bo'sh slotlar shundan hisoblanadi.
model DoctorSchedule {
  id          String    @id @default(uuid()) @db.Uuid
  clinicId    String    @map("clinic_id") @db.Uuid
  doctorId    String    @map("doctor_id") @db.Uuid
  weekday     Int
  startTime   String    @map("start_time") // "HH:MM" (mahalliy)
  endTime     String    @map("end_time") // "HH:MM" (mahalliy)
  slotMinutes Int       @map("slot_minutes")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@index([clinicId, doctorId, weekday])
  @@map("doctor_schedules")
}

// ---- QABULLAR (spec 7.6) ----
// Double-booking: bitta doctor + vaqt oralig'i takrorlanmasin. Migration SQL'da
// EXCLUDE (btree_gist) constraint + servisda advisory-lock (parallel xavfsizlik).
// status: PENDING | ARRIVED | IN_PROGRESS | COMPLETED | CANCELLED | NO_SHOW.
model Appointment {
  id          String    @id @default(uuid()) @db.Uuid
  clinicId    String    @map("clinic_id") @db.Uuid
  patientId   String    @map("patient_id") @db.Uuid
  doctorId    String    @map("doctor_id") @db.Uuid
  serviceId   String?   @map("service_id") @db.Uuid
  scheduledAt DateTime  @map("scheduled_at") @db.Timestamptz(6)
  endsAt      DateTime  @map("ends_at") @db.Timestamptz(6)
  status      String    @default("PENDING")
  notes       String?
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  patient         Patient                    @relation(fields: [patientId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  service         Service?                   @relation(fields: [serviceId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  statusHistory   AppointmentStatusHistory[]
  patientInvoices PatientInvoice[]
  medicalRecords  MedicalRecord[]

  @@index([clinicId, doctorId, scheduledAt])
  @@index([clinicId, patientId])
  @@index([clinicId, scheduledAt])
  // Hisobot (Phase 7B): status kesimida (no-show foizi, shifokor yuklamasi).
  @@index([clinicId, status, scheduledAt])
  @@map("appointments")
}

// ---- QABUL HOLATI TARIXI (spec 7.6 / 11.5 — ML uchun, append-only) ----
model AppointmentStatusHistory {
  id            String   @id @default(uuid()) @db.Uuid
  clinicId      String   @map("clinic_id") @db.Uuid
  appointmentId String   @map("appointment_id") @db.Uuid
  oldStatus     String?  @map("old_status")
  newStatus     String   @map("new_status")
  changedBy     String?  @map("changed_by") @db.Uuid
  changedAt     DateTime @default(now()) @map("changed_at") @db.Timestamptz(6)

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([appointmentId, changedAt])
  @@map("appointment_status_history")
}

// ---- BEMOR HISOB-FAKTURASI (klinika kassasi, spec 7.9) ----
// Abonent to'lovidan (invoices/transactions) ALOHIDA. status: UNPAID | PARTIAL |
// PAID | CANCELLED. debt_amount = total - paid (denormalized).
model PatientInvoice {
  id            String    @id @default(uuid()) @db.Uuid
  clinicId      String    @map("clinic_id") @db.Uuid
  patientId     String    @map("patient_id") @db.Uuid
  appointmentId String?   @map("appointment_id") @db.Uuid
  totalAmount   Decimal   @map("total_amount") @db.Decimal(14, 2)
  paidAmount    Decimal   @default(0) @map("paid_amount") @db.Decimal(14, 2)
  debtAmount    Decimal   @map("debt_amount") @db.Decimal(14, 2)
  currency      String    @default("UZS")
  status        String    @default("UNPAID")
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(6)

  patient     Patient          @relation(fields: [patientId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  appointment Appointment?     @relation(fields: [appointmentId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  payments    PatientPayment[]

  @@index([clinicId, status])
  @@index([clinicId, patientId])
  @@map("invoices_patient")
}

// ---- BEMOR TO'LOVLARI (ledger — soft-delete YO'Q, bo'lib-bo'lib to'lash) ----
// method: CASH | CARD | PAYME | CLICK. cashier_id — kim qabul qilgani.
model PatientPayment {
  id               String   @id @default(uuid()) @db.Uuid
  clinicId         String   @map("clinic_id") @db.Uuid
  patientInvoiceId String   @map("patient_invoice_id") @db.Uuid
  patientId        String   @map("patient_id") @db.Uuid
  amount           Decimal  @db.Decimal(14, 2)
  method           String
  status           String   @default("COMPLETED")
  paidAt           DateTime @default(now()) @map("paid_at") @db.Timestamptz(6)
  cashierId        String?  @map("cashier_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  invoice PatientInvoice @relation(fields: [patientInvoiceId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([clinicId, createdAt])
  // Hisobot (Phase 7B): daromad paid_at bo'yicha guruhlanadi — alohida indeks.
  @@index([clinicId, paidAt])
  @@index([patientInvoiceId])
  @@map("patient_payments")
}

// =============================================================================
// Phase 6 — Tibbiy yozuvlar (EMR) + retsept
// =============================================================================
// MAXFIY ma'lumot (spec 10): tenant izolyatsiyasi qat'iy, faqat DOCTOR/NURSE/
// CLINIC_ADMIN kiradi, har o'qish audit log'ga yoziladi. doctor_id va clinic_id —
// UUID ustun (FK migration SQL'da). Skanlangan fayllar -> files moduli
// (owner_type=MEDICAL_RECORD). prescription_items — normallashtirilgan retsept.

model MedicalRecord {
  id            String    @id @default(uuid()) @db.Uuid
  clinicId      String    @map("clinic_id") @db.Uuid
  patientId     String    @map("patient_id") @db.Uuid
  appointmentId String?   @map("appointment_id") @db.Uuid
  doctorId      String    @map("doctor_id") @db.Uuid
  complaints    String? // shikoyatlar
  diagnosis     String? // tashxis
  icdCode       String?   @map("icd_code") // ICD-10 kod
  treatment     String? // davolash
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(6)

  patient      Patient           @relation(fields: [patientId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  appointment  Appointment?      @relation(fields: [appointmentId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  prescriptions PrescriptionItem[]

  @@index([clinicId, patientId, createdAt])
  @@index([clinicId, createdAt])
  @@index([appointmentId])
  @@map("medical_records")
}

// ---- RETSEPT QATORLARI (normallashtirilgan — bir ko'rikда ko'p dori) ----
model PrescriptionItem {
  id              String    @id @default(uuid()) @db.Uuid
  clinicId        String    @map("clinic_id") @db.Uuid
  medicalRecordId String    @map("medical_record_id") @db.Uuid
  drugName        String    @map("drug_name")
  dosage          String? // masalan "500 mg"
  frequency       String? // masalan "kuniga 2 marta"
  duration        String? // masalan "7 kun"
  instructions    String?
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz(6)

  medicalRecord MedicalRecord @relation(fields: [medicalRecordId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([clinicId, medicalRecordId])
  @@map("prescription_items")
}

// =============================================================================
// Phase 7A — Telegram akkaunt bog'lash (markaziy bot, multi-tenant)
// =============================================================================
// Bir martalik link_token -> /start <token> -> telegram_chat_id bog'lanadi.
// FAQAT status=LINKED chat'ga xabar yuboriladi (spec 12). clinic_id — UUID ustun
// (FK migration SQL'da). owner_type: PATIENT | USER (shifokor/xodim).
model TelegramLink {
  id             String    @id @default(uuid()) @db.Uuid
  clinicId       String    @map("clinic_id") @db.Uuid
  ownerType      String    @map("owner_type") // PATIENT | USER
  ownerId        String    @map("owner_id") @db.Uuid
  telegramChatId String?   @map("telegram_chat_id") // bog'langach to'ldiriladi
  linkToken      String    @map("link_token") // bir martalik
  status         String    @default("PENDING") // PENDING | LINKED
  linkedAt       DateTime? @map("linked_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)

  // Partial unique: link_token; (clinic_id, owner_type, owner_id) WHERE LINKED -> migration SQL
  @@index([clinicId, ownerType, ownerId])
  @@index([telegramChatId])
  @@map("telegram_links")
}
