# =============================================================================
# Klinika CRM — PRODUCTION stack sirlari (namuna)
# =============================================================================
# Haqiqiy qiymatlarni `.env.production` ga yozing (GIT'ga TUSHMASIN).
# Eng yaxshisi: bu qiymatlarni secret-manager (Vault / AWS Secrets Manager /
# Docker secrets) orqali env injection qiling — fayl faqat dev/staging uchun.
# =============================================================================

# Ommaviy URL (TLS domeni). CORS va cookie shu domenga moslanadi.
PUBLIC_URL=https://crm.example.uz

# --- PostgreSQL ---
POSTGRES_USER=clinic
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=clinic_crm

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# --- MinIO (S3) ---
MINIO_ROOT_USER=CHANGE_ME_minio_user
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password
MINIO_BUCKET=clinic-files

# --- JWT (kamida 32 belgi, tasodifiy) ---
JWT_ACCESS_SECRET=CHANGE_ME_random_32+_chars_access
JWT_REFRESH_SECRET=CHANGE_ME_random_32+_chars_refresh

# --- Maydon shifrlash (Phase 9B): base64(32 bayt). MAJBURIY. YO'QOTMANG! ---
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
FIELD_ENCRYPTION_KEY=CHANGE_ME_base64_32_bytes
FIELD_ENCRYPTION_KEY_ID=k1
# Rotatsiyada eski kalitlar (deshifrlash): "k0:base64,k-1:base64"
FIELD_ENCRYPTION_KEYS_OLD=

# --- Observability ---
LOG_LEVEL=info
SENTRY_DSN=
SENTRY_ENV=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# --- To'lov provayderlari (Payme / Click) — sirlar ---
PAYME_MERCHANT_ID=
PAYME_MERCHANT_KEY=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=
CLICK_MERCHANT_ID=
CLICK_MERCHANT_USER_ID=

# --- SMS (Eskiz) / Telegram bot ---
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_DOMAIN=
